{
  "name": "@klarlabs-studio/warden",
  "version": "0.7.0",
  "description": "Configurable git commit/push gate — native hooks, worktree isolation, cryptographic provenance. Wraps the warden binary so `npx @klarlabs-studio/warden` works with no Go toolchain.",
  "bin": {
    "warden": "bin/warden.cjs"
  },
  "files": [
    "bin/warden.cjs",
    "README.md"
  ],
  "optionalDependencies": {
    "@klarlabs-studio/warden-linux-x64": "0.7.0",
    "@klarlabs-studio/warden-linux-arm64": "0.7.0",
    "@klarlabs-studio/warden-darwin-x64": "0.7.0",
    "@klarlabs-studio/warden-darwin-arm64": "0.7.0",
    "@klarlabs-studio/warden-win32-x64": "0.7.0",
    "@klarlabs-studio/warden-win32-arm64": "0.7.0"
  },
  "keywords": [
    "git",
    "hooks",
    "pre-commit",
    "pre-push",
    "gate",
    "lint",
    "ci"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/klarlabs-studio/warden.git"
  },
  "homepage": "https://go.klarlabs.de/warden",
  "engines": {
    "node": ">=16"
  }
}
